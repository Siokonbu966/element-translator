{
  "manifest_version": 3,
  "name": "Element Translator",
  "version": "0.1.0",
  "description": "Translate clicked <p>/<li> text and show in popup with history.",
  "action": {
    "default_title": "Translate Element",
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
